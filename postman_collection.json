{
  "info": {
    "name": "Gestão de Contas Bancárias",
    "description": "Colecção da API. Comece por 'Login admin' — o token fica guardado automaticamente e é usado pelos restantes pedidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Registar cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) pm.collectionVariables.set('token', pm.response.json().token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"maria\",\n  \"password\": \"maria123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        }
      ]
    },
    {
      "name": "Contas",
      "item": [
        {
          "name": "Criar conta (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Maria Santos\",\n  \"nuit\": \"123456789\",\n  \"type\": \"ORDEM\",\n  \"initialBalance\": 1000,\n  \"ownerUsername\": \"maria\"\n}"
            },
            "url": "{{baseUrl}}/api/accounts"
          }
        },
        {
          "name": "Listar todas as contas (admin)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/accounts" }
        },
        {
          "name": "As minhas contas (cliente)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/accounts/mine" }
        },
        {
          "name": "Consultar conta",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/accounts/1" }
        },
        {
          "name": "Consultar saldo",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/accounts/1/balance" }
        },
        {
          "name": "Extracto de movimentos",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/accounts/1/statement" }
        },
        {
          "name": "Depositar (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"description\": \"Deposito ao balcao\"\n}"
            },
            "url": "{{baseUrl}}/api/accounts/1/deposit"
          }
        }
      ]
    },
    {
      "name": "Transferências",
      "item": [
        {
          "name": "Transferir entre contas",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sourceAccountNumber\": \"<nº conta origem>\",\n  \"destinationAccountNumber\": \"<nº conta destino>\",\n  \"amount\": 250,\n  \"description\": \"Renda de Julho\"\n}"
            },
            "url": "{{baseUrl}}/api/transfers"
          }
        }
      ]
    }
  ]
}
